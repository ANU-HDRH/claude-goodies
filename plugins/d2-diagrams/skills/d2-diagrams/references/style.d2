# GENERATED from tokens.json by build-style.py — do not hand-edit.
# The house ROLE vocabulary for D2: spread in with `...@style`, then tag objects by role,
# e.g. `api: API Gateway { class: svc }`. Colours mirror tokens.json; shapes are D2-native
# (in Mermaid/PlantUML a role gives colour only — pick the shape per roles.md).

vars: {
  d2-config: { theme-id: 0; pad: 40 }
}

classes: {
  # service / process / running component (the default box)
  svc: { style: { fill: "#eef2ff"; stroke: "#4f46e5"; stroke-width: 2; font-color: "#312e81"; border-radius: 8 } }
  # a human or external role that initiates something
  actor: { shape: person; style: { fill: "#f1f5f9"; stroke: "#475569"; stroke-width: 2; font-color: "#1e293b" } }
  # a branch point in a flow
  decision: { shape: diamond; style: { fill: "#fff1f2"; stroke: "#e11d48"; stroke-width: 2; font-color: "#881337" } }
  # a database / persistent datastore
  store: { shape: cylinder; style: { fill: "#fffbeb"; stroke: "#d97706"; stroke-width: 2; font-color: "#78350f" } }
  # a queue / stream / buffer
  queue: { shape: queue; style: { fill: "#ecfdf5"; stroke: "#059669"; stroke-width: 2; font-color: "#064e3b" } }
  # an input / data source (file set, spreadsheet, RO-Crate, feed)
  source: { style: { fill: "#c9f7c9"; stroke: "#1f8b1f"; stroke-width: 2; font-color: "#0b5c0b"; border-radius: 6 } }
  # a transform / build step that emits an artefact
  process: { style: { fill: "#ede9fe"; stroke: "#6d28d9"; stroke-width: 2; font-color: "#4c1d95"; border-radius: 6 } }
  # a produced output (built site, bundle, report)
  artefact: { style: { fill: "#fef3c7"; stroke: "#b45309"; stroke-width: 2; font-color: "#7c2d12"; border-radius: 6 } }
  # a hosting / infrastructure component (web server, CDN)
  infra: { style: { fill: "#cce5ff"; stroke: "#4682b4"; stroke-width: 2; font-color: "#1f4b6e"; border-radius: 6 } }
  # a logical grouping / boundary container
  group: { style: { fill: "#fafafa"; stroke: "#cbd5e1"; stroke-width: 1; font-color: "#475569" } }
  # a third-party / out-of-our-control system (dashed)
  external: { style: { fill: "#eceff3"; stroke: "#6b7280"; stroke-width: 2; stroke-dash: 4; font-color: "#374151" } }
  # on-canvas note / legend. Use a PLAIN quoted label with your own \n breaks, NOT a |md|
  # block (d2 clips a long single-line md and shows only the first paragraph). One per diagram.
  caption: { style: { fill: "#fbfbfd"; stroke: "#cbd5e1"; stroke-width: 1; font-size: 14; font-color: "#334155" } }
  # an internal data flow between build-time steps (edge)
  flow: { style: { stroke: "#2f4b7c"; stroke-width: 2 } }
  # a person acting on something (maintain, set up, review) (edge)
  human: { style: { stroke: "#b45309"; stroke-width: 2 } }
  # a bold cross-boundary publish / hand-off (deploy, deposit) (edge)
  publish: { style: { stroke: "#8b0000"; stroke-width: 3 } }
  # an access / consumption path (dashed) (edge)
  serve: { style: { stroke: "#4682b4"; stroke-width: 2; stroke-dash: 5 } }
  # an optional / async dependency (edge)
  weak: { style: { stroke: "#94a3b8"; stroke-dash: 4 } }
}
